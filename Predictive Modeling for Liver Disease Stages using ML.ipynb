import pandas as pd


df = pd.read_csv('/kaggle/input/datasets/fedesoriano/cirrhosis-prediction-dataset/cirrhosis.csv')

# প্রথম ৫টি রো দেখা
print(df.head())

# missing value and data type
print(df.info())
print("\nMissing Values:\n", df.isnull().sum())





# column drop 
df_cleaned = df.drop(['ID', 'N_Days', 'Status'], axis=1)

#after drop
print(df_cleaned.columns)


from sklearn.preprocessing import LabelEncoder

le = LabelEncoder()

# column of text format
categorical_cols = ['Sex', 'Ascites', 'Hepatomegaly', 'Spiders', 'Edema', 'Drug']

for col in categorical_cols:
    # convert the missing value into str to avoid labelEncoder error
    df_cleaned[col] = df_cleaned[col].astype(str)
    df_cleaned[col] = le.fit_transform(df_cleaned[col])

print("Encoding done.")
print(df_cleaned.head())


from sklearn.impute import KNNImputer

# imputer create 5 data to take the closest data set
imputer = KNNImputer(n_neighbors=5)

# full dataset impute
df_imputed = pd.DataFrame(imputer.fit_transform(df_cleaned), columns=df_cleaned.columns)


print("remainin missing value:", df_imputed.isnull().sum().sum())


from sklearn.preprocessing import StandardScaler

# feature (X) and target (y) separate
X = df_imputed.drop('Stage', axis=1)
y = df_imputed['Stage']

# scaling
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

print("preprocessing done")


#data imbalance check,,
import matplotlib.pyplot as plt
import seaborn as sns

# 4 stage show the patient 
sns.countplot(x=y)
plt.title('Distribution of Liver Stages')
plt.show()


plt.figure(figsize=(12,8))
sns.heatmap(df_imputed.corr(), annot=True, cmap='coolwarm', fmt='.2f')
plt.title('Feature Correlation Heatmap')
plt.show()





from sklearn.model_selection import train_test_split

# 80% for train and 20% for test
X_train, X_test, y_train, y_test = train_test_split(X_scaled, y, test_size=0.2, random_state=42)

print(f"Training set size: {X_train.shape[0]}")
print(f"Testing set size: {X_test.shape[0]}")


# if 'y' or Stage column have in float then convert into int 
y_train = y_train.astype(int)
y_test = y_test.astype(int)

# now train the model
dt_model.fit(X_train, y_train)

print("model train successfull7")



from imblearn.over_sampling import SMOTE

#data balance
sm = SMOTE(random_state=42)
X_train_res, y_train_res = sm.fit_resample(X_train, y_train)

print("training dataset after balance:", X_train_res.shape)





# #model create and training by decision treee

from sklearn.tree import DecisionTreeClassifier

# মডেল তৈরি (আমরা max_depth ৪ রাখছি যাতে ট্রি-টি খুব বেশি বড় না হয় এবং বুঝতে সুবিধা হয়)
dt_model = DecisionTreeClassifier(criterion='entropy', max_depth=4, random_state=42)

# মডেলকে ট্রেইন করা
dt_model.fit(X_train, y_train)

print("Decision Tree donee")


#checking accuracy and performance check

from sklearn.metrics import accuracy_score, classification_report, confusion_matrix

# predict by test data
y_pred = dt_model.predict(X_test)

# result
print("Accuracy Score:", accuracy_score(y_test, y_pred))
print("\nClassification Report:\n", classification_report(y_test, y_pred))






from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import classification_report, accuracy_score

# optimize model create
rf_model_final = RandomForestClassifier(n_estimators=100, max_depth=10, random_state=42)

# training by balanced dataset
rf_model_final.fit(X_train_res, y_train_res)

# prediction and result
y_pred_final = rf_model_final.predict(X_test)

print("Final Accuracy:", accuracy_score(y_test, y_pred_final))
print("\nFinal Classification Report:\n", classification_report(y_test, y_pred_final))





from xgboost import XGBClassifier
from sklearn.metrics import classification_report, accuracy_score
from sklearn.preprocessing import LabelEncoder

# XGBoost সাধারণত ক্লাস ০ থেকে শুরু করতে পছন্দ করে
# আমাদের স্টেজ ১, ২, ৩, ৪ আছে, তাই এগুলোকে ০, ১, ২, ৩ এ রূপান্তর করি
le_stage = LabelEncoder()
y_train_res_xgb = le_stage.fit_transform(y_train_res)
y_test_xgb = le_stage.transform(y_test)

# XGBoost মডেল তৈরি
xgb_model = XGBClassifier(
    n_estimators=100,
    learning_rate=0.1,
    max_depth=6,
    objective='multi:softprob', # মাল্টি-ক্লাস সমস্যার জন্য
    random_state=42
)

# মডেল ট্রেনিং (ব্যালেন্সড ডেটা দিয়ে)
xgb_model.fit(X_train_res, y_train_res_xgb)

# প্রেডিকশন
y_pred_xgb = xgb_model.predict(X_test)

# রেজাল্ট দেখা
print("XGBoost Accuracy:", accuracy_score(y_test_xgb, y_pred_xgb))
print("\nClassification Report:\n", classification_report(y_test_xgb, y_pred_xgb))





import numpy as np
import pandas as pd
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier

# ১. ইম্পিউটেড ডেটা থেকে একটা কপি নিচ্ছি যাতে মূল ডেটা নষ্ট না হয়
df_binary = df_imputed.copy()

# ২. স্টেজগুলোকে ২ ভাগে ভাগ করছি (১, ২ -> ০ এবং ৩, ৪ -> ১)
# map ব্যবহার করার পর যদি কোনো ভ্যালু ১-৪ এর বাইরে থাকে তবে তা NaN হয়ে যায়
df_binary['Binary_Stage'] = df_binary['Stage'].map({1: 0, 2: 0, 3: 1, 4: 1})

# ৩. টার্গেট কলামে (y) যদি কোনো NaN থাকে তবে সেই পুরো রোগীকে ড্রপ করা
df_binary = df_binary.dropna(subset=['Binary_Stage'])

# ৪. টার্গেটকে পূর্ণসংখ্যায় (Integer) রূপান্তর করা (এটি খুবই গুরুত্বপূর্ণ)
df_binary['Binary_Stage'] = df_binary['Binary_Stage'].astype(int)

# ৫. ফিচার (X) এবং টার্গেট (y) আলাদা করা
X_b = df_binary.drop(['Stage', 'Binary_Stage'], axis=1)
y_b = df_binary['Binary_Stage']

# ৬. ট্রেইন এবং টেস্ট স্প্লিট
X_train_b, X_test_b, y_train_b, y_test_b = train_test_split(X_b, y_b, test_size=0.2, random_state=42)

# ৭. মডেল ট্রেইনিং
rf_binary = RandomForestClassifier(n_estimators=100, class_weight='balanced', random_state=42)
rf_binary.fit(X_train_b, y_train_b)

# ৮. রেজাল্ট দেখা
print(f"Binary Classification Accuracy: {rf_binary.score(X_test_b, y_test_b) * 100:.2f}%")


from sklearn.metrics import confusion_matrix, classification_report
import seaborn as sns
import matplotlib.pyplot as plt

# prediction
y_pred_b = rf_binary.predict(X_test_b)

# matrix create
cm_b = confusion_matrix(y_test_b, y_pred_b)

plt.figure(figsize=(6,5))
sns.heatmap(cm_b, annot=True, fmt='d', cmap='Reds', 
            xticklabels=['Low Risk (1-2)', 'High Risk (3-4)'], 
            yticklabels=['Low Risk (1-2)', 'High Risk (3-4)'])
plt.xlabel('Predicted')
plt.ylabel('Actual')
plt.title('Binary Classification Confusion Matrix')
plt.show()

print(classification_report(y_test_b, y_pred_b))








import matplotlib.pyplot as plt
import seaborn as sns

# মডেলের নাম এবং একুরেসি স্কোর
models = ['Decision Tree', 'Random Forest (SMOTE)', 'XGBoost', 'Binary RF']
accuracies = [47.6, 48.8, 45.2, 68.6]

plt.figure(figsize=(10, 6))

# এখানে hue=models এবং legend=False যোগ করা হয়েছে ওয়ার্নিং এড়াতে
sns.barplot(x=models, y=accuracies, hue=models, palette='magma', legend=False)

# গ্রাফের ওপর ভ্যালু বসানো
for i, val in enumerate(accuracies):
    plt.text(i, val + 1, f'{val}%', ha='center', fontsize=12)

plt.ylim(0, 100)
plt.title('Performance Comparison of Different Models', fontsize=15)
plt.ylabel('Accuracy (%)')
plt.grid(axis='y', linestyle='--', alpha=0.7)
plt.show()





# Random Forest থেকে ফিচার ইম্পর্টেন্স নেওয়া
importances = rf_binary.feature_importances_
feature_names = X_b.columns

# সর্ট করে সুন্দরভাবে সাজানো
feature_df = pd.DataFrame({'Feature': feature_names, 'Importance': importances})
feature_df = feature_df.sort_values(by='Importance', ascending=True)

plt.figure(figsize=(10, 8))
plt.barh(feature_df['Feature'], feature_df['Importance'], color='skyblue')
plt.xlabel('Importance Score')
plt.title('Which Medical Features are Most Critical?')
plt.show()


from sklearn.metrics import confusion_matrix
import seaborn as sns

y_pred_b = rf_binary.predict(X_test_b)
